# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
!certs/localhost.pem
!certs/localhost-key.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.cache

# local env files
# keep .env.example as a template (exception must come first)
!.env.example
.env*.local
.env.bak
.env.local.bak
# ignore .env files (but not .env.example due to exception above)
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# amplify
.amplify
amplify_outputs*
amplifyconfiguration*


/.old

certificates

# dev session version (generated on npm run dev)
/public/session-version.json

# temporary files
*.bak
npx
coordy@1.0.0
renkei.txt

# old backup directories
old-backup/
DOCS/old/

# cursor settings (optional - remove if you want to track)
.cursor/

# Supabase local files (keep .gitignore but ignore other local files)
supabase/.branches
supabase/.temp
supabase/.env

# personal memos
DOCS/MyselfMemo
backup_latest.dump
scripts/admin-user-info.txt
